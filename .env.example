# App mode: mock | api
VITE_APP_MODE=api

# Backend API URL
VITE_API_URL=https://your-api-server.com
VITE_COOKIE_AUTH=false

# Firebase Configuration (get from Firebase Console → Project Settings)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
# Web Push certificate key pair (Project settings → Cloud Messaging → Web Push certificates).
# Required for push notifications; leave blank to disable push entirely.
VITE_FIREBASE_VAPID_KEY=your_web_push_vapid_key

# Audio assets base URL (S3 or CDN)
VITE_AUDIO_BASE_URL=https://your-bucket.s3.region.amazonaws.com/audio

# Sentry error tracking
# DSN is public-safe (Sentry → Settings → Projects → [project] → Client Keys).
# Leave VITE_SENTRY_DSN blank to disable Sentry entirely (e.g. local dev).
VITE_SENTRY_DSN=your_sentry_dsn
# Optional: overrides the environment label in Sentry (defaults to build mode).
VITE_SENTRY_ENVIRONMENT=
# Optional: fraction of transactions sampled for performance monitoring (0–1, defaults to 0.2).
VITE_SENTRY_TRACES_RATE=
# --- Build-only secrets (NO VITE_ prefix → never shipped to the browser) ---
# Used only to upload source maps at build time. Create the token at:
# Sentry → Settings → Developer Settings → Organization Tokens.
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=prajaakeeya
SENTRY_PROJECT=prajaakeeya-frontend
